; Fold regions for VBA block constructs.
[
  (sub_declaration)
  (function_declaration)
  (property_declaration)
  (declare_statement)
  (type_declaration)
  (enum_declaration)
  (with_statement)
  (do_statement)
  (for_statement)
  (for_each_statement)
  (while_statement)
  (select_statement)
  (if_statement)
  (case_clause)
  (case_else_clause)
  (preprocessor_if)
] @fold
